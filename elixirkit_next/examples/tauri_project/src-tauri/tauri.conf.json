{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "example",
  "version": "0.1.0",
  "identifier": "com.example",
  "app": {
    "windows": [
      {
        "title": "ElixirKit Example",
        "width": 800,
        "height": 600,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "resources": {
      "resources/rel": "rel"
    },
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
