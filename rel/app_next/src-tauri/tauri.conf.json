{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LivebookTest",
  "identifier": "dev.livebook.Livebook",
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["livemd"],
        "name": "Livebook",
        "role": "Editor"
      }
    ],
    "macOS": {
      "entitlements": "App.entitlements",
      "exceptionDomain": null,
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["livebook"]
      }
    }
  }
}
